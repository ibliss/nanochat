# Copy this file to .env and edit. Loaded automatically when you run from the nanochat repo root.
# NANOCHAT_BASE_DIR  = path for data, checkpoints, tokenizer (default: ~/.cache/nanochat)
# CUDA_VISIBLE_DEVICES = which GPUs to use (e.g. 0 or 0,1). Must be set before PyTorch imports.

NANOCHAT_BASE_DIR=./data
CUDA_VISIBLE_DEVICES=0
